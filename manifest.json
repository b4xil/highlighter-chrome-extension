{
  "manifest_version": 3,
  "name": "Highlight Saver",
  "version": "1.0",
  "permissions": ["storage", "activeTab", "scripting"],

  "host_permissions": [
    "http://localhost:3000/"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup/popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"],
      "css": ["styles.css"]
    }
  ]
}